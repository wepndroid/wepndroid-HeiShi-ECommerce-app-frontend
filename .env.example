# Environment variables (copy to `.env` for local development)

EXPO_PUBLIC_API_URL=https://api.heishi.app/v1
EXPO_PUBLIC_API_MOCK_FALLBACK=true

# Supabase Auth (Path A — phone OTP). Anon key only — safe for the mobile app.
EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Phone auth provider for sign-up/login.
# Use "backend" to force Twilio-backed backend auth even when Supabase is configured.
EXPO_PUBLIC_PHONE_AUTH_PROVIDER=supabase

# WeChat Open Platform login. This is the public AppID for the native app.
# Android package/signature and iOS universal link must match WeChat Open Platform.
EXPO_PUBLIC_WECHAT_APP_ID=
EXPO_PUBLIC_WECHAT_UNIVERSAL_LINK=

# Stripe publishable key (pk_...) for the in-app PaymentSheet. Publishable key only —
# safe to ship in the app. Requires a dev/prod build (the Stripe native module does not
# run in Expo Go). Must match the STRIPE_SECRET_KEY set on the backend.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
