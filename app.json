{
  "expo": {
    "name": "heishi-mvp-rn",
    "slug": "heishi-mvp-rn",
    "scheme": [
      "heymarket",
      "heishi"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logos/app_icon.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.heishi.mvp",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VISUAL_USER_SELECTED",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFD21C",
        "foregroundImage": "./src/assets/logos/app_icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/logos/app_icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8f4c2b1a-3d5e-4f6a-9b0c-1d2e3f4a5b6c"
      }
    },
    "plugins": [
      "expo-localization",
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/logos/app_icon.png",
          "color": "#F5C518",
          "defaultChannel": "chat-messages",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HeyMarket to access your photos so you can upload listing images.",
          "cameraPermission": "Allow HeyMarket to use the camera to take listing photos."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.heishi.mvp",
          "enableGooglePay": true
        }
      ],
      "@react-native-google-signin/google-signin"
    ]
  }
}
